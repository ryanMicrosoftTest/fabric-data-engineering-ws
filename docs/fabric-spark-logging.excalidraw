    {
      "id": "k8VrnnrYi4aHYQTCOe2Lc",
      "type": "text",
      "x": 273.6450835328635,
      "y": 4221.066794168476,
      "width": 799.0824091290773,
      "height": 212.4712343643159,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "aS",
      "roundness": null,
      "seed": 1894568399,
      "version": 238,
      "versionNonce": 195027499,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1774635649403,
      "link": null,
      "locked": false,
      "text": "Spark Properties\nspark.synapse.diagnostic.emitters: event-hub-name\nspark.synapse.diagnostic.emitter.spark-eh.type: AzureEventHub\nspark.synapse.diagnostic.emitter.spark-eh.categories: DriverLog, ExecutorLog\nspark.synapse.diagnostic.emitter.spark-eh.secret: Connection String\nspark.synapse.diagnostic.emitter.spark-eh.filter.loggerName.match: logger name\n\n",
      "fontSize": 21.24712343643159,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Spark Properties\nspark.synapse.diagnostic.emitters: event-hub-name\nspark.synapse.diagnostic.emitter.spark-eh.type: AzureEventHub\nspark.synapse.diagnostic.emitter.spark-eh.categories: DriverLog, ExecutorLog\nspark.synapse.diagnostic.emitter.spark-eh.secret: Connection String\nspark.synapse.diagnostic.emitter.spark-eh.filter.loggerName.match: logger name\n\n",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "I_8qg12TLXxRLojeHLCky",
      "type": "text",
      "x": 276.2309315016478,
      "y": 4512.105915433007,
      "width": 926.37939453125,
      "height": 275,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "aT",
      "roundness": null,
      "seed": 1709835855,
      "version": 285,
      "versionNonce": 1700291787,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1774635649403,
      "link": null,
      "locked": false,
      "text": "Notebook\nConfigurate a log4j logger because python's logging module doesn't propogate to executor logs\nThe log4j logger integrates natively with Spark driver/executor logs\n\n\nExample:\nlog4jLogger = spark._jvm.org.apache.log4j\nlogger = log4jLogger.LogManager.getLogger(\"PySparkLogger\")\nlogger.setLevel(log4jLogger.Level.INFO)\nlogger.info(\"Application started.\")\n",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Notebook\nConfigurate a log4j logger because python's logging module doesn't propogate to executor logs\nThe log4j logger integrates natively with Spark driver/executor logs\n\n\nExample:\nlog4jLogger = spark._jvm.org.apache.log4j\nlogger = log4jLogger.LogManager.getLogger(\"PySparkLogger\")\nlogger.setLevel(log4jLogger.Level.INFO)\nlogger.info(\"Application started.\")\n",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "WUacwoMYgyOsBNkUlNcg5",
      "type": "text",
      "x": 279.2309315016478,
      "y": 4870.105915433007,
      "width": 173.3479461669922,
      "height": 35,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "aW",
