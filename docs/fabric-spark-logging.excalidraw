    {
      "id": "pL6WWmdHQCQRPjlE-N28q",
      "type": "text",
      "x": 220,
      "y": 1329,
      "width": 1868.23876953125,
      "height": 150,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "aN",
      "roundness": null,
      "seed": 127279503,
      "version": 872,
      "versionNonce": 2111692737,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1770230914468,
      "link": null,
      "locked": false,
      "text": "Use Case:\nHow to best do logging in spark applications in Fabric.  Logging to a lakehouse leads to high latency because spark is designed for large engineering jobs, so there is significant \noverhead (creating a spark stage, jobs, sending them to workers, following ACID compliance to write to a table, etc).  This is not a good pattern for logging, since logging is a lot\nof smaller writes.  The ideal solution will persist to a location in near real time, support driver and executor visibility, allow for custom logging, and safely handle concurrency.  To achieve this,\nthe best pattern is the use of a spark diagnostic emitter to an event hub (to allow for fast writes).  Then for an eventstream to ingest the logs into a EventHouse via an EventStream to \ncreate alerts and perform analytics.",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Use Case:\nHow to best do logging in spark applications in Fabric.  Logging to a lakehouse leads to high latency because spark is designed for large engineering jobs, so there is significant \noverhead (creating a spark stage, jobs, sending them to workers, following ACID compliance to write to a table, etc).  This is not a good pattern for logging, since logging is a lot\nof smaller writes.  The ideal solution will persist to a location in near real time, support driver and executor visibility, allow for custom logging, and safely handle concurrency.  To achieve this,\nthe best pattern is the use of a spark diagnostic emitter to an event hub (to allow for fast writes).  Then for an eventstream to ingest the logs into a EventHouse via an EventStream to \ncreate alerts and perform analytics.",
      "autoResize": true,
      "lineHeight": 1.25
    },
