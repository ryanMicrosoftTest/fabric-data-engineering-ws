    },
    {
      "id": "6lp4PFIYk2sBllcOEFmaV",
      "type": "text",
      "x": 276.2309315016478,
      "y": 5195.105976468163,
      "width": 1009.8592529296875,
      "height": 75,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "aZ",
      "roundness": null,
      "seed": 40276833,
      "version": 434,
      "versionNonce": 494282571,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1774635649403,
      "link": null,
      "locked": false,
      "text": "The EventHouse houses a KQL Database where the logs finally land.  Alerts can be configured here as \nwell.  This is primarily used to search logs for debugging purposes (or otherwise whatever logs are \npersisted here).  ",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "The EventHouse houses a KQL Database where the logs finally land.  Alerts can be configured here as \nwell.  This is primarily used to search logs for debugging purposes (or otherwise whatever logs are \npersisted here).  ",
      "autoResize": true,
      "lineHeight": 1.25
    },
