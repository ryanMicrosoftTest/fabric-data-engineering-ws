      "seed": 1892545903,
      "version": 124,
      "versionNonce": 103256939,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1774635649403,
      "link": null,
      "locked": false,
      "text": "EventStream",
      "fontSize": 28,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "EventStream",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "1eXZ5xOO5RyfFOiGHg4Ge",
      "type": "text",
      "x": 278.2309315016478,
      "y": 4947.105915433007,
      "width": 979.6393432617188,
      "height": 250,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "aX",
      "roundness": null,
      "seed": 306166607,
      "version": 419,
      "versionNonce": 777514507,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1774635649403,
      "link": null,
      "locked": false,
      "text": "The eventstream is used to pull the logs from the event hub into the EventHouse in Fabric.\nThis is connected to via an EventHubs Connector using a Primary or Secondary Key to authenticate\nrather than the primary or secondary connection string\n\n\n\n\n\n\n",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "The eventstream is used to pull the logs from the event hub into the EventHouse in Fabric.\nThis is connected to via an EventHubs Connector using a Primary or Secondary Key to authenticate\nrather than the primary or secondary connection string\n\n\n\n\n\n\n",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "fXkfpfQKKnYJu5hENZ97F",
      "type": "text",
      "x": 276.2309315016478,
      "y": 5122.772602444726,
      "width": 158.17193603515625,
      "height": 35,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "aY",
      "roundness": null,
      "seed": 1244687841,
      "version": 163,
      "versionNonce": 820245675,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1774635649403,
      "link": null,
      "locked": false,
      "text": "EventHouse",
      "fontSize": 28,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "EventHouse",
      "autoResize": true,
