      "seed": 1112343002,
      "version": 296,
      "versionNonce": 1202551238,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1771442467590,
      "link": null,
      "locked": false,
      "text": "Data_Lakehouse has OneLake Security Enabled\nUsing User's Identity as OneLake access mode\n\n\nRoles in Data_Lakehouse\nDefaultReader\nNeurologyRole\nGastroenterologyRole\nOrthopedicRole\n\nAll roles are applied to a table named doctor_table",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Data_Lakehouse has OneLake Security Enabled\nUsing User's Identity as OneLake access mode\n\n\nRoles in Data_Lakehouse\nDefaultReader\nNeurologyRole\nGastroenterologyRole\nOrthopedicRole\n\nAll roles are applied to a table named doctor_table",
      "autoResize": true,
      "lineHeight": 1.25
    },
