    {
      "id": "VOjre-ggaMj34ZndB-VbF",
      "type": "text",
      "x": 1299.2618795834564,
      "y": 254.15590244064367,
      "width": 833.5794677734375,
      "height": 125,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
