      "index": "b0N",
      "roundness": null,
      "seed": 1619668965,
      "version": 377,
      "versionNonce": 1110652133,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1773857365462,
      "link": null,
      "locked": false,
      "text": "Having different subnets is the better approach for this because it allows \nsmaller subnets to be allocated from the VNet when needed as opposed to having\nto create a large subnet for expected usage over time and having those IPs tied up.\nUnderstanding this, this does introduce additional subnet management as the \ntrade off",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Having different subnets is the better approach for this because it allows \nsmaller subnets to be allocated from the VNet when needed as opposed to having\nto create a large subnet for expected usage over time and having those IPs tied up.\nUnderstanding this, this does introduce additional subnet management as the \ntrade off",
      "autoResize": true,
      "lineHeight": 1.25
    },
