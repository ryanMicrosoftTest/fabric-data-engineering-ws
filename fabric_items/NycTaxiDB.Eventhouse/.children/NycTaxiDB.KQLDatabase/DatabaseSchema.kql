.create-merge table nyctaxinew (VendorID:int, tpep_pickup_datetime:datetime, tpep_dropoff_datetime:datetime, passenger_count:long, trip_distance:real, RatecodeID:real, store_and_fwd_flag:string, PULocationID:long, DOLocationID:long, payment_type:long, fare_amount:real, extra:real, mta_tax:real, tip_amount:real, tolls_amount:real, improvement_surcharge:real, total_amount:real, congestion_surcharge:real, airport_fee:real)
