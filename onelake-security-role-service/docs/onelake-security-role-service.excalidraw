      "link": null,
      "locked": false,
      "text": "At the repository level,\nthere's a directory named\nonelake-security-role-service",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "At the repository level,\nthere's a directory named\nonelake-security-role-service",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "c5616ftJpgZmWX2D8ULJ_",
      "type": "text",
      "x": 403.83331298828125,
      "y": -568.166748046875,
      "width": 286.3997802734375,
      "height": 175,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "ad",
      "roundness": null,
      "seed": 185871894,
      "version": 176,
      "versionNonce": 615147978,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1776690060308,
      "link": null,
      "locked": false,
      "text": "Within that directory, there's\na pyproject.toml file that \npoints to the src/\ndirectory.  This is to \nbuild a python module named\nonelake-security\n",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Within that directory, there's\na pyproject.toml file that \npoints to the src/\ndirectory.  This is to \nbuild a python module named\nonelake-security\n",
