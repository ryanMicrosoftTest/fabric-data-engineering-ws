      "id": "cls1-desc",
      "type": "text",
      "x": 520,
      "y": 372,
      "width": 280,
      "height": 228,
      "text": "CLASS:\nPreconditionFailedError:\nRaised when a PUT fails\nwith 412 \u2014 the ETag is\nstale. The caller\n(workflow service) should\nre-fetch, re-reconcile,\nand retry.",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "CLASS:\nPreconditionFailedError:\nRaised when a PUT fails\nwith 412 \u2014 the ETag is\nstale. The caller\n(workflow service) should\nre-fetch, re-reconcile,\nand retry.",
      "lineHeight": 1.25,
      "baseline": 18
    },
