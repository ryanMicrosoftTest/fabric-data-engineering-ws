      "width": 970,
      "height": 168,
      "text": "\n+ __init__(writer, correlation_id)\n+ log(operation, role_name, workspace_id, item_id, success, source_file, content_hash, error)\n+ flush() : None\n+ to_dicts() : list[dict]\n",
