      "id": "cls0-desc",
      "type": "text",
      "x": 80,
      "y": 382,
      "width": 460,
      "height": 280,
      "text": "MODULE: file_tracker: File tracking \u2014\ncontent hash watermarking for change\ndetection. Tracks which YAML files have been\nprocessed and their content hashes, so the\ndaily pipeline only processes files that\nhave actually changed.\n\nMETHODS:\n+ compute_content_hash(content: str):\nCompute a SHA-256 hash of the file content.",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "MODULE: file_tracker: File tracking \u2014\ncontent hash watermarking for change\ndetection. Tracks which YAML files have been\nprocessed and their content hashes, so the\ndaily pipeline only processes files that\nhave actually changed.\n\nMETHODS:\n+ compute_content_hash(content: str):\nCompute a SHA-256 hash of the file content.",
      "lineHeight": 1.25,
      "baseline": 18
    },
