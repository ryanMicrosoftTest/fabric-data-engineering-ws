      "id": "cls1-meth-t",
      "type": "text",
      "x": 740,
      "y": 246,
      "width": 700,
      "height": 192,
      "text": "\n+ __init__()\n+ from_state(state: dict[str, str]) : FileTracker  <<classmethod>>\n+ has_changed(file_path: str, content_hash: str) : bool\n+ mark_applied(file_path: str, content_hash: str) : None\n+ get_state() : dict[str, str]\n",
      "fontSize": 16,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "middle",
      "containerId": "cls1-meth",
      "originalText": "\n+ __init__()\n+ from_state(state: dict[str, str]) : FileTracker  <<classmethod>>\n+ has_changed(file_path: str, content_hash: str) : bool\n+ mark_applied(file_path: str, content_hash: str) : None\n+ get_state() : dict[str, str]\n",
      "lineHeight": 1.25,
      "baseline": 14
    },
    {
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
